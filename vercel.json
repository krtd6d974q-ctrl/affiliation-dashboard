{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/r.html",     "destination": "/r.html" },
    { "source": "/pages/:path*", "destination": "/pages/:path*" },
    { "source": "/css/:path*",   "destination": "/css/:path*" },
    { "source": "/js/:path*",    "destination": "/js/:path*" },
    { "source": "/index.html",   "destination": "/index.html" },
    { "source": "/",             "destination": "/index.html" },
    { "source": "/:slug",        "destination": "/api/r/:slug" }
  ]
}
